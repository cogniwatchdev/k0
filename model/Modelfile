# K-0 Pentest Model — wraps xploiter/pentester with tool-calling support
# Build: ollama create k0-pentest -f ./Modelfile
FROM xploiter/pentester:latest

# Tool-calling template: enables Ollama's native tool calling API
TEMPLATE """{{- if .System }}
<|start_header_id|>system<|end_header_id|>

{{ .System }}
{{- end }}

{{- if .Tools }}

Available tools:
{{ .Tools }}
{{- end }}

<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}
<|start_header_id|>assistant<|end_header_id|>

{{ .Response }}"""

# NO SYSTEM prompt here — the Go code controls system prompts per-call
# to avoid double-prompting and wasted tokens.

# Tuning for fast structured output
PARAMETER temperature 0.2
PARAMETER num_predict 2048
PARAMETER num_ctx 4096
PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|end_header_id|>"
